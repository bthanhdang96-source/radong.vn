{
  "name": "nongsanvn-server",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "crawler:customs": "tsx scripts/runCustomsCrawler.ts",
    "crawler:preflight": "tsx scripts/crawlerPreflight.ts",
    "crawler:shopee": "tsx scripts/runShopeeCrawler.ts",
    "crawler:shopee:refresh-session": "tsx scripts/refreshShopeeSession.ts",
    "crawler:status": "tsx scripts/crawlerStatus.ts",
    "dev": "tsx watch index.ts",
    "ingestion:sample": "tsx scripts/enqueueSampleIngestion.ts",
    "ingestion:verify": "tsx scripts/verifySampleIngestion.ts",
    "start": "tsx index.ts",
    "monitor": "tsx services/ingestion/monitor.ts",
    "typecheck": "tsc --noEmit",
    "worker": "tsx services/ingestion/worker.ts",
    "worker:once": "tsx services/ingestion/worker.ts --once"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "redis": "^4.7.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^24.12.2",
    "tsx": "^4.19.4"
  }
